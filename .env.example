# ========================================
# 上海金铃橡胶制品有限公司 - 环境变量配置
# ========================================

# ----------------------------------------
# 询盘邮件通知配置
# ----------------------------------------

# 接收询盘通知的邮箱（不会显示在网页上）
INQUIRY_EMAIL=andyww@citiz.net

# ----------------------------------------
# 邮件发送服务配置（二选一）
# ----------------------------------------

# 方式1: Resend API（推荐，免费额度3000封/月）
# 注册地址: https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# 方式2: SMTP配置（传统方式）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@jinling-rubber.com

# ----------------------------------------
# 注意事项
# ----------------------------------------
# 1. 配置邮件服务后，询盘通知会自动发送到 INQUIRY_EMAIL
# 2. 如果没有配置邮件服务，询盘信息会打印到服务器日志
# 3. 生产环境建议配置邮件服务，确保及时收到询盘通知

# ----------------------------------------
# 更换邮箱说明
# ----------------------------------------
# 申请企业邮箱后，只需修改 INQUIRY_EMAIL 即可
# 例如: INQUIRY_EMAIL=sales@jinling-rubber.com
